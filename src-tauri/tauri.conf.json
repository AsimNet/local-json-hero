{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Local JSON Hero",
  "version": "0.1.0",
  "identifier": "io.jsonhero.local-desktop",
  "build": {
    "beforeDevCommand": "npm run desktop:dev:web",
    "beforeBuildCommand": "npm run desktop:build:web",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist-desktop"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Local JSON Hero",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "visible": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "capabilities": ["main"],
      "csp": {
        "default-src": "'self' tauri://localhost asset: http://asset.localhost",
        "connect-src": "ipc: http://ipc.localhost",
        "img-src": "'self' tauri://localhost asset: http://asset.localhost blob: data:",
        "media-src": "'self' tauri://localhost asset: http://asset.localhost blob: data:",
        "script-src": "'self' 'unsafe-inline' tauri://localhost asset: http://asset.localhost",
        "style-src": "'self' 'unsafe-inline' tauri://localhost asset: http://asset.localhost",
        "worker-src": "'self' tauri://localhost asset: http://asset.localhost blob:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "category": "DeveloperTool",
    "copyright": "Copyright JSONHero contributors",
    "fileAssociations": [
      {
        "name": "JSON Document",
        "description": "JSON document",
        "ext": ["json"],
        "mimeType": "application/json",
        "role": "Viewer"
      },
      {
        "name": "JSON Lines Document",
        "description": "JSONL or NDJSON document",
        "ext": ["jsonl", "ndjson"],
        "mimeType": "application/x-ndjson",
        "role": "Viewer"
      }
    ],
    "macOS": {
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.15"
    }
  }
}
